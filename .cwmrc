sticky yes
snapdist 20
gap  10 10 10 10 
fontname "Hack:size=16:antialias=true"
borderwidth 1
color activeborder "#ef2f27"
color inactiveborder "#918175"

unbind-key CM-Return
bind-key C-Return "st"
bind-key CM-n "st -e ncmpcpp"
bind-key M-p passmenu
unbind CM-w
bind-key CM-w "chromium-browser-ungoogled" 
bind-key XF86_AudioMute "pactl set-sink-mute 0 toggle"
bind-key XF86_AudioRaiseVolume "pactl set-sink-volume 0 +5%" 
bind-key XF86_AudioLowerVolume "pactl set-sink-volume 0 -5%" 
bind-key CM-space window-htile
bind-key CMS-space window-vtile

ignore "termbar"
autogroup 0 "termbar,termbar"
