sticky yes

# set default to Hermit
fontname "Hermit:size=14:style=bold"

autogroup 0     "termbar,termbar"
ignore termbar

# window stuff
borderwidth 0
gap 30 0 0 0
menubg "#080808"
menufc "#bcbcbc"
# window tiling screen real-estate is set to 50%
htile 50
vtile 50

# set default terminal bind to spawn xterm in a new tmux session
unbind-key CM-Return
bind-key CM-Return      "urxvtc -e tmux -2"
#bind-key CMS-Return     "urxvt  -e tmux -2 && xdotool key ctrl+alt+m"

# window tiling
unbind-key M-right
unbind-key M-left
bind-key CM-z window-vtile
bind-key CMS-z window-htile

# other stuff
bind-key XF86AudioRaiseVolume "pamixer --allow-boost -i 10"
bind-key XF86AudioLowerVolume "pamixer --allow-boost -d 10"
bind-key XF86AudioMute        "pamixer -t"
# for laptops
bind-key M-F9                 "xbacklight -dec 10"
bind-key M-F10                "xbacklight -inc 10"
bind-key CM-b                 "notify-send $(acpi)"
