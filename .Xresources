*.faceName: Terminus:size=20
URxvt.font: xft:Terminus:size=20
URxvt.scrollBar: false

dzen2.font: -*-fixed-*-*-*-*-*-*-*-*-*-*-*-*
dzen2.foreground: #d8caac
dzen2.background: #323d43

! special
*.foreground:   #d8caac
*.background:   #323d43
*.cursorColor:  #d8caac
URxvt*depth:    32
URxvt.background: [80]#323d43

! black
*.color0:       #868d80
*.color8:       #868d80

! red
*.color1:       #e68183
*.color9:       #e68183

! green
*.color2:       #a7c080
*.color10:      #a7c080

! yellow
*.color3:       #d9bb80
*.color11:      #d9bb80

! blue
*.color4:       #89beba
*.color12:      #89beba

! magenta
*.color5:       #d3a0bc
*.color13:      #d3a0bc

! cyan
*.color6:       #87c095
*.color14:      #87c095

! white
*.color7:       #d8caac
*.color15:      #d8caac
