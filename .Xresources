Xft.dpi:  96
Xft.antialias: true
Xft.rgba: rgb
Xft.hinting: true
Xft.hintstyle: hintfull
XTerm.faceName: xft:Hack:pixelsize=20:antialias=true
URxvt*font: xft:Hack:pixelsize=20:antialias=true
XTerm*selectToClipboard: true
XTerm*vt100.scrollBar: true
URxvt*scrollBar:  false
XTerm*scrollTtyOutput: true
XTerm*highlightSelection: true
XTerm*trimSelection: true
XTerm*scrollBar: true
XTerm.vt100.translations:
  Meta <KeyPress> V: insert-selection(CLIPBOARD, PRIMARY, CUT_BUFFER0)  
URxvt.cursorBlink: true
URxvt.depth: 32
URxvt.keysym.M-v: eval:paste_clipboard
*.scrollBar.minimumThumb: 50
*.scrollbar.width: 10
URxvt.scrollBar_right: true
XTerm.rightScrollBar: true
! this is only needed in ratpoison (no EMWH compliance), as xterm/urxvt doesnt draw their shape correctly
XTerm.allowSendEvents: true
!*.internalBorder: 6 

*.foreground: #bcbcbc
*.background: #1c1c1c
URxvt.background: [75]#1c1c1c
*.cursorColor: #bcbcbc

*.color0: #1c1c1c
*.color1: #d75f5f
*.color2: #87af87
*.color3: #afaf87
*.color4: #5f87af
*.color5: #af87af
*.color6: #5f8787
*.color7: #9e9e9e
*.color8: #767676
*.color9: #d7875f
*.color10: #afd7ad
*.color11: #d7d787
*.color12: #87afd7
*.color13: #d7afd7
*.color14: #87adad
*.color15: #bcbcbc
