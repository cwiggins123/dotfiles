*.faceName: xft:Hermit:size=14
XTerm*selectToClipboard: true
XTerm*vt100.scrollBar: false
XTerm*scrollTtyOutput: false
XTerm*highlightSelection: true
XTerm*trimSelection: true

! special
*.foreground:   #dfaf8f
*.background:   #3f3f3f
*.cursorColor:  #dfaf8f

! black
*.color0:       #3f3f3f
*.color8:       #4f4f4f

! red
*.color1:       #e37170
*.color9:       #cc9393

! green
*.color2:       #688060
*.color10:      #ccd990

! yellow
*.color3:       #bc6c4c
*.color11:      #e3ceab

! blue
*.color4:       #6c6c9c
*.color12:      #8c8cbc

! magenta
*.color5:       #bc6c9c
*.color13:      #bc8cbc

! cyan
*.color6:       #709080
*.color14:      #9fafaf

! white
*.color7:       #5b605e
*.color15:      #dfaf8f
