*.faceName: Hermit:size=18
URxvt.scrollBar: false
URxvt.font: xft:Hermit:size=18

!! moonfly theme ! special
*.foreground:   #b2b2b2
*.background:   #080808
*.cursorColor:  #9e9e9e
URxvt.depth:  32
URxvt.background: [25]#080808

! black
*.color0:       #323437
*.color8:       #949494

! red
*.color1:       #ff5454
*.color9:       #ff5189

! green
*.color2:       #8cc85f
*.color10:      #36c692

! yellow
*.color3:       #e3c78a
*.color11:      #c2c292

! blue
*.color4:       #80a0ff
*.color12:      #74b2ff

! magenta
*.color5:       #d183e8
*.color13:      #ae81ff

! cyan
*.color6:       #79dac8
*.color14:      #85dc85

! white
*.color7:       #c6c6c6
*.color15:      #e4e4e4
