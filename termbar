#!/bin/bash

while true; do
  BAT_STATUS=$(cat /sys/class/power_supply/BAT0/status)
  BAT=$(cat /sys/class/power_supply/BAT0/capacity)
  DATE=$(date)
  if $(pamixer --get-mute); then
    VOL="MUTE"
  else
    VOL=$(pamixer --get-volume)
  fi
  echo -en "  VOL: $VOL | BAT: $BAT - $BAT_STATUS | $DATE\r"
  sleep 1
done 
