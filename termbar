#!/bin/bash

while true ; do
  BAT=$(acpi | sed s/'Battery 0'/'BAT'/ | sed s/,// | sed s/,// | cut --complement -d " " -f2)
  DATE=$(date)
  #BCKLT=$(xbacklight | cut -d "." -f1)
  TEMP=$(acpi -t | cut -d " " -f 4)

  # doesn't work, I'm only trying it because of my vehement hatred of
  # if statements. It totally would if bash had logical xor
  # VOL=$(pamixer --get-volume) || ($(pamixer --get-mute) && VOL="MUTE") 

  if $(pamixer --get-mute); then
    VOL="MUTE"
  else
    VOL=$(pamixer --get-volume)
  fi

    echo "VOL: $VOL | $BAT | $DATE | TEMP: $TEMP"
  sleep 1
done 

