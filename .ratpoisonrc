# my super cool ratpoison config
exec xcompmgr
exec dunst
# for keyboards other than the moonlander
#exec xmodmap ~/.xmodmap
exec !(pidof tmux) && tmux

unbind C-c
unbind c
bind C-c exec uxterm -e tmux attach 
bind c exec uxterm -e tmux attach 
bind M-l exec slock
unbind C-v
unbind v
bind C-v echo  "VOL: $(pamixer --get-volume)"
bind v exec notify-send  "VOL: $(pamixer --get-volume)"
# battery info for laptops
#bind b exec notify-send "$(acpi)"
bind g abort
bind w exec chromium
bind C-w exec chromium

rudeness 13
set barborder 1
set wingravity center
set transgravity center 
set bargravity center
set winname title
set fgcolor #b2b2b2
set bgcolor #080808
set font Terminus:size=18
set transgravity center
set bargravity center

# special keys without escape key
definekey top XF86_AudioMute exec pamixer -t 
definekey top XF86_AudioRaiseVolume exec pamixer -i 5 && notify-send "VOL: $(pamixer --get-volume)"
definekey top XF86_AudioLowerVolume exec pamixer -d 5 && notify-send "VOL: $(pamixer --get-volume)"

# for laptops
#definekey top C-F9 exec xbacklight -dec 10
#definekey top C-F10 exec xbacklight -inc 10

# for keyboards with no media buttons
#definekey top C-F10 exec pamixer --inc 10
#definekey top C-F9 exec pamixer --dec 10
#definekey top C-F8 exec pamixer -t
